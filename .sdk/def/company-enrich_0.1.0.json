{
  "openapi": "3.0.3",
  "info": {
    "title": "Company Enrich API",
    "description": "The Company Enrich API provides businesses with enriched, actionable insights about companies. It offers endpoints for company enrichment, search, and discovering similar companies, enabling users to make data-driven decisions and streamline their prospecting efforts.",
    "version": "1.0.0",
    "contact": {
      "url": "https://docs.companyenrich.com"
    },
    "termsOfService": "https://docs.companyenrich.com/terms"
  },
  "servers": [
    {
      "url": "https://api.companyenrich.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v1/enrich": {
      "get": {
        "summary": "Enrich Company Data",
        "description": "Retrieve enriched data about a company based on domain name or company identifier. Returns comprehensive company information including firmographics, technographics, and other actionable insights.",
        "operationId": "enrichCompany",
        "tags": [
          "Company Enrichment"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "description": "The domain name of the company to enrich (e.g., example.com)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "example.com"
            }
          },
          {
            "name": "company_id",
            "in": "query",
            "description": "The unique identifier of the company",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "The name of the company to enrich",
            "required": false,
            "schema": {
              "type": "string",
              "example": "Example Inc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with enriched company data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyEnrichmentResponse"
                },
                "example": {
                  "success": true,
                  "data": {
                    "company_id": "comp_123456",
                    "name": "Example Inc",
                    "domain": "example.com",
                    "description": "A leading technology company",
                    "industry": "Technology",
                    "employee_count": 500,
                    "founded_year": 2010,
                    "location": {
                      "city": "San Francisco",
                      "state": "California",
                      "country": "United States",
                      "address": "123 Main St"
                    },
                    "revenue": "$50M-$100M",
                    "technologies": [
                      "AWS",
                      "React",
                      "Node.js"
                    ],
                    "social_profiles": {
                      "linkedin": "https://linkedin.com/company/example",
                      "twitter": "https://twitter.com/example",
                      "facebook": "https://facebook.com/example"
                    },
                    "phone": "+1-555-0100",
                    "email": "contact@example.com",
                    "logo_url": "https://example.com/logo.png"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Company not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/search": {
      "get": {
        "summary": "Search Companies",
        "description": "Search for companies based on various criteria such as industry, location, size, and more. Returns a list of matching companies with basic information.",
        "operationId": "searchCompanies",
        "tags": [
          "Company Search"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "required": false,
            "schema": {
              "type": "string",
              "example": "technology company"
            }
          },
          {
            "name": "industry",
            "in": "query",
            "description": "Filter by industry",
            "required": false,
            "schema": {
              "type": "string",
              "example": "Technology"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by location (city, state, or country)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "San Francisco"
            }
          },
          {
            "name": "employee_count_min",
            "in": "query",
            "description": "Minimum number of employees",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 100
            }
          },
          {
            "name": "employee_count_max",
            "in": "query",
            "description": "Maximum number of employees",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 1000
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return (max 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100,
              "example": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanySearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/similar": {
      "get": {
        "summary": "Find Similar Companies",
        "description": "Discover companies similar to a given company based on industry, size, location, and other attributes. Useful for competitive analysis and prospecting.",
        "operationId": "findSimilarCompanies",
        "tags": [
          "Similar Companies"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "query",
            "description": "Domain of the reference company",
            "required": false,
            "schema": {
              "type": "string",
              "example": "example.com"
            }
          },
          {
            "name": "company_id",
            "in": "query",
            "description": "ID of the reference company",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of similar companies to return (max 50)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50,
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of similar companies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimilarCompaniesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Reference company not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Contact support to obtain your API key."
      }
    },
    "schemas": {
      "CompanyEnrichmentResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Indicates if the request was successful"
          },
          "data": {
            "$ref": "#/components/schemas/CompanyData"
          }
        }
      },
      "CompanyData": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "string",
            "description": "Unique identifier for the company"
          },
          "name": {
            "type": "string",
            "description": "Company name"
          },
          "domain": {
            "type": "string",
            "description": "Company website domain"
          },
          "description": {
            "type": "string",
            "description": "Company description"
          },
          "industry": {
            "type": "string",
            "description": "Primary industry"
          },
          "employee_count": {
            "type": "integer",
            "description": "Number of employees"
          },
          "founded_year": {
            "type": "integer",
            "description": "Year the company was founded"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "revenue": {
            "type": "string",
            "description": "Estimated revenue range"
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of technologies used by the company"
          },
          "social_profiles": {
            "$ref": "#/components/schemas/SocialProfiles"
          },
          "phone": {
            "type": "string",
            "description": "Company phone number"
          },
          "email": {
            "type": "string",
            "description": "Company contact email"
          },
          "logo_url": {
            "type": "string",
            "description": "URL to company logo"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "address": {
            "type": "string"
          }
        }
      },
      "SocialProfiles": {
        "type": "object",
        "properties": {
          "linkedin": {
            "type": "string"
          },
          "twitter": {
            "type": "string"
          },
          "facebook": {
            "type": "string"
          }
        }
      },
      "CompanySearchResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "total": {
            "type": "integer",
            "description": "Total number of matching companies"
          },
          "limit": {
            "type": "integer",
            "description": "Number of results returned"
          },
          "offset": {
            "type": "integer",
            "description": "Offset for pagination"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanySummary"
            }
          }
        }
      },
      "CompanySummary": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "employee_count": {
            "type": "integer"
          },
          "location": {
            "type": "string",
            "description": "Location summary"
          },
          "logo_url": {
            "type": "string"
          }
        }
      },
      "SimilarCompaniesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "reference_company": {
            "$ref": "#/components/schemas/CompanySummary"
          },
          "similar_companies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SimilarCompany"
            }
          }
        }
      },
      "SimilarCompany": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "employee_count": {
            "type": "integer"
          },
          "location": {
            "type": "string"
          },
          "similarity_score": {
            "type": "number",
            "format": "float",
            "description": "Similarity score (0-1)",
            "minimum": 0,
            "maximum": 1
          },
          "logo_url": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Error message"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Company Enrichment",
      "description": "Endpoints for enriching company data with comprehensive insights"
    },
    {
      "name": "Company Search",
      "description": "Search for companies based on various criteria"
    },
    {
      "name": "Similar Companies",
      "description": "Discover companies similar to a reference company"
    }
  ]
}
